# === CivicTrackGuard Backend Environment Variables ===
# Copy this file to .env and fill in your values.
# For Render deployment, set these in the Render Dashboard > Environment.

# Database (TiDB Cloud)
# Format: jdbc:mysql://<host>:<port>/<database>?sslMode=VERIFY_IDENTITY&enabledTLSProtocols=TLSv1.2,TLSv1.3
MYSQL_URL=
MYSQL_USERNAME=
MYSQL_PASSWORD=

# JWT Authentication (min 32 characters)
JWT_SECRET=

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini AI
GEMINI_API_KEY=

# Email Notifications (Gmail App Password)
MAIL_USERNAME=
MAIL_PASSWORD=

# Frontend URL (for CORS - your deployed frontend domain)
FRONTEND_URL=
